    <changeSet author="colvir-ms" created="2024-12-09" id="cre-requirement_hold" objectQuotingStrategy="LEGACY">
        <preConditions onError="HALT" onFail="MARK_RAN" onSqlOutput="IGNORE">
            <not>
                <tableExists tableName="requirement_hold"/>
                <primaryKeyExists primaryKeyName="requirement_holdPK" tableName="requirement_hold"/>
            </not>
        </preConditions>
        <createTable remarks="Холд по требованию" tableName="requirement_hold">
            <column autoIncrement="true" name="id" remarks="идентификатор (первичный ключ)" type="bigint">
                <constraints nullable="false" primaryKey="true" primaryKeyName="requirement_holdPK"/>
            </column>
            <column name="account_number" remarks="номер счета" type="VARCHAR(255)"/>
            <column name="amount" remarks="сумма" type="DECIMAL"/>
            <column name="currency_id" remarks="валюта" type="BIGINT"/>
            <column name="hold_id" remarks="холд по online счету" type="BIGINT"/>
            <column defaultValueBoolean="false" name="is_deleted" remarks="является удалённым объектом" type="BOOLEAN"/>
            <column name="master_object_000" remarks="обобщенная ссылка на владельца(мастера)" type="VARCHAR(255)"/>
            <column name="reference" remarks="рефернс холда во внешней системе" type="VARCHAR(255)"/>
            <column name="withdrawal_type_id" remarks="вариант списания денег" type="BIGINT"/>
            <column name="requirement_of_assigned_holds_id" remarks="установленные холды" type="bigint"/>
        </createTable>
        <rollback>
            <renameTable newTableName="requirement_hold__bk19" oldTableName="requirement_hold"/>
        </rollback>
    </changeSet>
