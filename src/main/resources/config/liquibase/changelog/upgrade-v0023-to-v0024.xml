            <column name="distribution_amount" remarks="сумма распределения" type="DECIMAL"/>
            <column defaultValueBoolean="false" name="is_deleted" remarks="является удалённым объектом" type="BOOLEAN"/>
            <column name="refunding_payment_id" remarks="платеж по возврату средств клиенту" type="bigint"/>
            <column name="requirement_of_refunding_payments_id" remarks="платежи по возврату" type="bigint"/>
        </createTable>
        <rollback>
            <renameTable newTableName="requirement_refunding_payment__bk24" oldTableName="requirement_refunding_payment"/>
        </rollback>
