    <changeSet author="colvir-ms" created="2025-07-24" id="cre-refunding_payment" objectQuotingStrategy="LEGACY">
        <preConditions onError="HALT" onFail="MARK_RAN" onSqlOutput="IGNORE">
            <not>
                <tableExists tableName="refunding_payment"/>
                <primaryKeyExists primaryKeyName="refunding_paymentPK" tableName="refunding_payment"/>
            </not>
        </preConditions>
        <createTable remarks="Платеж по возврату средств клиенту" tableName="refunding_payment">
            <column autoIncrement="true" name="id" remarks="идентификатор (первичный ключ)" type="bigint">
                <constraints nullable="false" primaryKey="true" primaryKeyName="refunding_paymentPK"/>
            </column>
            <column name="amount" remarks="сумма" type="DECIMAL"/>
            <column name="currency_id" remarks="валюта" type="BIGINT"/>
            <column name="edit_date" remarks="дата редактирования" type="TIMESTAMP"/>
            <column name="editor_id" remarks="редактор" type="BIGINT"/>
            <column name="executor_id" remarks="исполнитель" type="BIGINT"/>
            <column defaultValueBoolean="false" name="is_deleted" remarks="является удалённым объектом" type="BOOLEAN"/>
            <column name="payment_link_type" remarks="вид связи с платежом" type="VARCHAR(255)"/>
            <column name="payment_result" remarks="результат оплаты" type="VARCHAR(255)"/>
            <column name="provision_method_id" remarks="вариант выплаты" type="BIGINT"/>
            <column name="reference" remarks="референс платежа" type="VARCHAR(1000)"/>
            <column name="value_date" remarks="дата валютирования" type="DATE"/>
            <column defaultValueNumeric="0" name="version" remarks="номер версии" type="INTEGER"/>
        </createTable>
        <rollback>
            <renameTable newTableName="refunding_payment__bk24" oldTableName="refunding_payment"/>
        </rollback>
    </changeSet>
