    <changeSet author="colvir-ms" created="2024-09-25" id="upd-enum-payment.payment_link_type" objectQuotingStrategy="LEGACY">
        <validCheckSum>9:82c06f631ef52243d8f38e2cffcb0c90</validCheckSum>
        <validCheckSum>9:e7b7e4b0de35c2cc3583707295e2dfb3</validCheckSum>
        <preConditions onError="CONTINUE" onFail="MARK_RAN" onSqlOutput="IGNORE">
            <and>
                <tableExists tableName="payment"/>
                <columnExists columnName="payment_link_type" tableName="payment"/>
            </and>
        </preConditions>
        <sql splitStatements="true" stripComments="false">update "payment" set "payment_link_type" = CASE "payment_link_type"
WHEN 'AUTO' THEN 'AUTO' 
WHEN 'MANUAL' THEN 'MANUAL' 
WHEN 'REQUIRE' THEN 'REQUIREMENT' 
ELSE "payment_link_type" END
where "payment_link_type" in ('AUTO', 'MANUAL', 'REQUIRE');</sql>
    </changeSet>
